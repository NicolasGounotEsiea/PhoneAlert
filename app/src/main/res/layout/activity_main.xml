<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:text="@string/main_title"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:text="@string/main_subtitle" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="@string/alarm_section"
            android:textSize="18sp"
            android:textStyle="bold" />

        <RadioGroup
            android:id="@+id/sirenGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp">

            <RadioButton
                android:id="@+id/sirenPolice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/siren_police" />

            <RadioButton
                android:id="@+id/sirenWail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/siren_wail" />

            <RadioButton
                android:id="@+id/sirenYelp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/siren_yelp" />

            <RadioButton
                android:id="@+id/sirenBeep"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/siren_beep" />
        </RadioGroup>

        <Button
            android:id="@+id/previewButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/preview_play" />

        <Button
            android:id="@+id/triggerButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="@string/trigger_button" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:textSize="13sp"
            android:text="@string/trigger_hint" />
    </LinearLayout>
</ScrollView>
